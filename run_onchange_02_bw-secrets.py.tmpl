#!/usr/bin/env python3
import json
import os
import stat
import subprocess
import sys
import shutil


# Use a user-specific directory so the CLI is isolated from the Bitwarden
# Desktop app (which intercepts and invalidates CLI sessions on Windows) and
# from other users on shared machines. Login state persists between runs;
# the vault is re-locked at the end.
_bw_data_dir = os.path.join(os.path.expanduser("~"), ".cache", "bw-chezmoi")
os.makedirs(_bw_data_dir, exist_ok=True)
os.environ.setdefault("BITWARDENCLI_APPDATA_DIR", _bw_data_dir)


AWS_ACCOUNTS = [(a["folder"], a["item"], a["profile"])  for a in {{ .aws_accounts | toJson }}]
SSH_KEYS     = [(k["folder"], k["item"], k["basename"]) for k in {{ .ssh_keys | toJson }}]


def find_bw():
    bw_path = shutil.which("bw")
    if bw_path:
        return bw_path

    for path in [
        os.path.expanduser("~/.local/bin/bw"),
        "/usr/local/bin/bw",
        "/opt/homebrew/bin/bw",
    ]:
        if os.path.isfile(path) and os.access(path, os.X_OK):
            return path

    raise RuntimeError("bw not found")

bw_path = find_bw()


def bw(args, capture=True):
    result = subprocess.run(
        [bw_path] + args,
        stdout=subprocess.PIPE if capture else None,
        text=True,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)
    return result.stdout.strip() if capture else None


def ensure_unlocked():
    # BW_SESSION from the calling shell is already in os.environ; use it if present.
    status_data = json.loads(bw(["status"]))
    status = status_data["status"]

    if status == "unlocked":
        return

    email = status_data.get("userEmail")

    if status == "locked":
        # bw unlock --raw with piped stdout produces an invalid token; logout and
        # re-login with the known email instead (same single password prompt).
        subprocess.run([bw_path, "logout"], capture_output=True)

    # unauthenticated (either originally or after logout above)
    # login --raw outputs the session token to stdout; prompts go to the tty.
    cmd = [bw_path, "login", "--raw"]
    if email:
        cmd = [bw_path, "login", email, "--raw"]
    result = subprocess.run(cmd, stdout=subprocess.PIPE, text=True, check=True)
    os.environ["BW_SESSION"] = result.stdout.strip()


def get_item(folder, item_name, folders):
    items = json.loads(bw(["list", "items", "--search", item_name]))
    if folder:
        folder_id = folders.get(folder)
        if folder_id is None:
            print(f"Error: no BitWarden folder named '{folder}'", file=sys.stderr)
            sys.exit(1)
        items = [i for i in items if i.get("folderId") == folder_id]
    if not items:
        loc = f"folder '{folder}'" if folder else "vault"
        print(f"Error: '{item_name}' not found in {loc}", file=sys.stderr)
        sys.exit(1)
    return items[0]


def write_file(path, content, mode):
    with open(path, "w") as f:
        f.write(content)
    os.chmod(path, mode)


def main():
    print("Connecting to BitWarden to provision secrets (AWS credentials, SSH keys)...")
    ensure_unlocked()
    try:
        bw(["sync"], capture=False)

        folders = {f["name"]: f["id"] for f in json.loads(bw(["list", "folders"]))}

        # --- AWS credentials ---
        aws_dir = os.path.expanduser("~/.aws")
        os.makedirs(aws_dir, exist_ok=True)

        lines = []
        for folder, item_name, profile in AWS_ACCOUNTS:
            item = get_item(folder, item_name, folders)
            fields = {f["name"]: f["value"] for f in item.get("fields", [])}
            uris = item.get("login", {}).get("uris", [])
            entry = [f"[{profile}]"]
            if uris:
                entry.append(f"# {uris[0]['uri']}")
            entry += [
                f"aws_access_key_id = {fields['Access Key ID']}",
                f"aws_secret_access_key = {fields['Secret Access Key']}",
                "",
            ]
            lines += entry
        write_file(os.path.join(aws_dir, "credentials"), "\n".join(lines),
                   stat.S_IRUSR | stat.S_IWUSR)

{{ if ne .chezmoi.os "linux" -}}
        # --- SSH keys ---
        ssh_dir = os.path.expanduser("~/.ssh")
        os.makedirs(ssh_dir, exist_ok=True)
        os.chmod(ssh_dir, stat.S_IRWXU)

        for folder, item_name, basename in SSH_KEYS:
            item = get_item(folder, item_name, folders)
            ssh_key = item["sshKey"]

            write_file(os.path.join(ssh_dir, f"{basename}.key"),
                       ssh_key["privateKey"] + "\n",
                       stat.S_IRUSR | stat.S_IWUSR)
            write_file(os.path.join(ssh_dir, f"{basename}.key.pub"),
                       ssh_key["publicKey"] + "\n",
                       stat.S_IRUSR | stat.S_IWUSR | stat.S_IRGRP | stat.S_IROTH)
{{ end }}
    finally:
        subprocess.run([bw_path, "lock"], capture_output=True)


if __name__ == "__main__":
    main()
