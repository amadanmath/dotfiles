#!/usr/bin/env python3
import json
import os
import stat
import subprocess
import sys


AWS_ACCOUNTS = [(a["folder"], a["item"], a["profile"])  for a in {{ .aws_accounts | toJson }}]
SSH_KEYS     = [(k["folder"], k["item"], k["basename"]) for k in {{ .ssh_keys | toJson }}]


bw_path = os.path.expanduser("~/.local/bin/bw")


def bw(args, env, capture=True):
    result = subprocess.run(
        [bw_path] + args,
        stdout=subprocess.PIPE if capture else None,
        text=True,
        env=env,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)
    return result.stdout.strip() if capture else None


def ensure_unlocked():
    env = os.environ.copy()
    status = json.loads(bw(["status"], env))["status"]
    if status == "unauthenticated":
        subprocess.run([bw_path, "login"], env=env, check=True)
    if status != "unlocked":
        result = subprocess.run(
            [bw_path, "unlock", "--raw"],
            stdout=subprocess.PIPE, text=True, env=env, check=True,
        )
        env["BW_SESSION"] = result.stdout.strip()
    return env


def get_item(folder, item_name, folders, env):
    items = json.loads(bw(["list", "items", "--search", item_name], env))
    if folder:
        folder_id = folders.get(folder)
        if folder_id is None:
            print(f"Error: no BitWarden folder named '{folder}'", file=sys.stderr)
            sys.exit(1)
        items = [i for i in items if i.get("folderId") == folder_id]
    if not items:
        loc = f"folder '{folder}'" if folder else "vault"
        print(f"Error: '{item_name}' not found in {loc}", file=sys.stderr)
        sys.exit(1)
    return items[0]


def write_file(path, content, mode):
    with open(path, "w") as f:
        f.write(content)
    os.chmod(path, mode)


def main():
    print("Connecting to BitWarden to provision secrets (AWS credentials, SSH keys)...")
    env = ensure_unlocked()
    bw(["sync"], env, capture=False)

    folders = {f["name"]: f["id"] for f in json.loads(bw(["list", "folders"], env))}

    # --- AWS credentials ---
    aws_dir = os.path.expanduser("~/.aws")
    os.makedirs(aws_dir, exist_ok=True)

    lines = []
    for folder, item_name, profile in AWS_ACCOUNTS:
        item = get_item(folder, item_name, folders, env)
        fields = {f["name"]: f["value"] for f in item.get("fields", [])}
        uris = item.get("login", {}).get("uris", [])
        entry = [f"[{profile}]"]
        if uris:
            entry.append(f"# {uris[0]['uri']}")
        entry += [
            f"aws_access_key_id = {fields['Access Key ID']}",
            f"aws_secret_access_key = {fields['Secret Access Key']}",
            "",
        ]
        lines += entry
    write_file(os.path.join(aws_dir, "credentials"), "\n".join(lines),
               stat.S_IRUSR | stat.S_IWUSR)

{{ if ne .chezmoi.os "linux" -}}
    # --- SSH keys ---
    ssh_dir = os.path.expanduser("~/.ssh")
    os.makedirs(ssh_dir, exist_ok=True)
    os.chmod(ssh_dir, stat.S_IRWXU)

    for folder, item_name, basename in SSH_KEYS:
        item = get_item(folder, item_name, folders, env)
        ssh_key = item["sshKey"]

        write_file(os.path.join(ssh_dir, f"{basename}.key"),
                   ssh_key["privateKey"] + "\n",
                   stat.S_IRUSR | stat.S_IWUSR)
        write_file(os.path.join(ssh_dir, f"{basename}.key.pub"),
                   ssh_key["publicKey"] + "\n",
                   stat.S_IRUSR | stat.S_IWUSR | stat.S_IRGRP | stat.S_IROTH)
{{ end -}}


if __name__ == "__main__":
    main()
