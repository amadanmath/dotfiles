# Select emacs-style key bindings
bindkey -e

# Deduplicate PATH entries automatically; prepend user-local bin.
typeset -aU path
path=("$HOME/.local/bin" $path)

# Windows Terminal advertises true-color support via $WT_SESSION.
[[ -n "$WT_SESSION" ]] && export COLORTERM=truecolor

# Locale and terminal color support.
export LANG=en_US.UTF-8
export CLICOLOR=1

# Hint for tools that inspect terminal background color (0 = dark).
export COLORFGBG="${COLORFGBG:-7;0}"

# Completion
autoload -Uz compinit
compinit -C

# Python interactive startup file.
[[ -f "$HOME/.config/python/startup.py" ]] && export PYTHONSTARTUP="$HOME/.config/python/startup.py"

# Homebrew — check Apple Silicon location first, fall back to Intel.
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Disable Ctrl+S terminal freeze.
unsetopt FLOW_CONTROL

export EDITOR=nvim

# Modular config.
[[ -f "$HOME/.zsh/aliases.zsh" ]] && source "$HOME/.zsh/aliases.zsh"
[[ -f "$HOME/.zsh/os.zsh"      ]] && source "$HOME/.zsh/os.zsh"
[[ -f "$HOME/.zsh/prompt.zsh"  ]] && source "$HOME/.zsh/prompt.zsh"

# Machine-local config, not tracked by chezmoi.
[[ -f "$HOME/.zsh/local.zsh" ]] && source "$HOME/.zsh/local.zsh"

# RVM — must be loaded after anything else that touches PATH or the prompt.
if [[ -d "$HOME/.rvm" ]]; then
  path=($path "$HOME/.rvm/bin")
  [[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm"
fi

# Starship prompt — overrides any prompt set by RVM etc.
command -v starship &>/dev/null && eval "$(starship init zsh)"

# direnv — must come after anything that manipulates the prompt.
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"
